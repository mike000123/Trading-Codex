# Copy this file to `.env` and fill in your credentials.
# `.env` is gitignored; `.env.example` is safe to commit.

# ─── Trading Mode ────────────────────────────────────────────────────────────
# "paper"        → Local simulation only. No orders leave your machine.
# "alpaca_paper" → Real API calls to Alpaca's PAPER account (no real money).
# "live"         → Real-money Alpaca live account. Never flip to this casually.
TRADING_MODE=paper

# ─── Alpaca API Credentials ───────────────────────────────────────────────────
# Paper: from https://app.alpaca.markets → Paper Trading → API Keys
ALPACA_PAPER_API_KEY=PK...your_paper_key_id...
ALPACA_PAPER_SECRET_KEY=...your_40_char_paper_secret...

# Live: from https://app.alpaca.markets → Live Trading → API Keys
# Leave blank until you're ready for real-money trading.
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_SECRET_KEY=

# ─── Risk Controls ────────────────────────────────────────────────────────────
MAX_CAPITAL_PER_TRADE_PCT=5.0
MAX_DAILY_LOSS_PCT=10.0
MAX_OPEN_POSITIONS=10
DEFAULT_MAX_LOSS_PCT_OF_CAPITAL=50.0

# ─── Database ────────────────────────────────────────────────────────────────
DB_PATH=db/trading.db
LOG_DIR=logs
