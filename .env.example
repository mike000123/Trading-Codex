# ─── Trading Mode ────────────────────────────────────────────────────────────
# "paper" or "live"  —  NEVER set to "live" without explicit double-confirmation
TRADING_MODE=paper

# ─── Alpaca API Credentials ───────────────────────────────────────────────────
# Paper trading keys (from https://app.alpaca.markets → Paper → API Keys)
ALPACA_PAPER_API_KEY=your_paper_key_here
ALPACA_PAPER_SECRET_KEY=your_paper_secret_here

# Live trading keys (from https://app.alpaca.markets → Live → API Keys)
# Leave blank until you are ready for live trading
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_SECRET_KEY=

# ─── Risk Controls ────────────────────────────────────────────────────────────
MAX_CAPITAL_PER_TRADE_PCT=5.0        # Max % of total portfolio per single trade
MAX_DAILY_LOSS_PCT=10.0              # Halt trading if daily loss exceeds this %
MAX_OPEN_POSITIONS=10                # Hard cap on simultaneous open positions
DEFAULT_MAX_LOSS_PCT_OF_CAPITAL=50.0 # Max loss per trade as % of trade capital

# ─── Database ────────────────────────────────────────────────────────────────
DB_PATH=db/trading.db
LOG_DIR=logs
